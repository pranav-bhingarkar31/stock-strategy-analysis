        "BOLLINGER BAND -BB"
      ],
      "metadata": {
        "id": "IS7PzKJvqtnm"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "stock['BB_Mid']=stock['SMA_20']\n",
        "std=stock['Close'].rolling(20).std().squeeze()\n",
        "stock['BB_Upper']=stock['BB_Mid']+2*std\n",
        "stock['BB_Lower']=stock['BB_Mid']-2*std"
