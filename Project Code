    {
      "cell_type": "markdown",
      "source": [
        "RSI RELATIVE STRENGTH INDEX"
      ],
      "metadata": {
        "id": "C4fPi4wTqtnm"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "delta=stock['Close'].diff().squeeze()\n",
        "gain=delta.clip(lower=0)\n",
        "loss=-delta.clip(upper=0)\n",
        "rs=gain/loss\n",
        "stock['RSI_14']=100-(100/(1+rs))"
      ],
      "metadata": {
        "id": "QU9moN5iqtnn"
      },
      "execution_count": null,
      "outputs": []
    },
