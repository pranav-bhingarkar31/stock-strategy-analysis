    {
      "cell_type": "code",
      "source": [
        "holding=False\n",
        "trades_SMA=[]\n",
        "\n",
        "\n",
        "for i in range(1,len(stock)):\n",
        "  close=stock['Close'][i]\n",
        "  yesterday_sma_20=stock['SMA_20'][i-1]\n",
        "  yesterday_sma_50=stock['SMA_50'][i-1]\n",
        "  today_sma_20=stock['SMA_20'][i]\n",
        "  today_sma_50=stock['SMA_50'][i]\n",
        "  if not holding:\n",
        "    if yesterday_sma_20<=yesterday_sma_50 and today_sma_20>today_sma_50:\n",
        "      buy_price=close\n",
        "      holding=True\n",
        "  else:\n",
        "      if yesterday_sma_20>=yesterday_sma_50 and today_sma_20<today_sma_50:\n",
        "        sell_price=close\n",
        "        returns=(sell_price-buy_price)/buy_price\n",
        "        trades_SMA.append(returns)\n",
        "        holding=False\n",
        "if holding:\n",
        "  sell_price=stock['Close'].iloc[-1]\n",
        "  returns=(sell_price-buy_price)/buy_price\n",
